# Database Configuration
DATABASE_TYPE=postgres
POSTGRES_USER=testops
POSTGRES_PASSWORD=testops123
POSTGRES_DB=testops
DATABASE_URL=postgresql://testops:testops123@postgres:5432/testops

# MongoDB Configuration (if using MongoDB instead of PostgreSQL)
MONGO_USER=admin
MONGO_PASSWORD=admin123
MONGO_DB=testops
MONGO_URL=mongodb://admin:admin123@testops-mongo:27017/?authSource=admin

# Redis Configuration
REDIS_URL=redis://redis:6379

# Backend Configuration
PORT=8080
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
ENVIRONMENT=development

# Frontend Configuration
VITE_API_URL=http://localhost:8090

# Runner Configuration
DISPLAY=:99

# =====================================
# Email Report Automation (Backend)
# Disabled by default; set EMAIL_AUTOSEND_ENABLED=true to enable.
# =====================================

EMAIL_AUTOSEND_ENABLED=true
EMAIL_POLL_INTERVAL_SECONDS=20
EMAIL_BATCH_LIMIT=5
EMAIL_MAX_LOG_BYTES=500000
EMAIL_RETRY_FAILED=false

# Frontend base URL used to generate links in emails
FRONTEND_BASE_URL=http://localhost:3456

# SMTP settings
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=hello.testhub@gmail.com
SMTP_PASSWORD=ylev siam fxkv jglc
SMTP_FROM=hello.testhub@gmail.com
SMTP_USE_STARTTLS=true
SMTP_USE_TLS=false
SMTP_INSECURE_SKIP_VERIFY=false
